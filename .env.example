# --- Telegram credentials ---
# Bot token from @BotFather
BOT_TOKEN=

# api_id / api_hash from https://my.telegram.org/apps
# Required so the bot can download files larger than 20 MB via MTProto.
API_ID=
API_HASH=

# --- Authorization ---
# Numeric Telegram user ID with admin privileges (use @userinfobot to find yours).
ADMIN_ID=

# --- Storage / quotas ---
# Working directory for downloaded files / parts. Cleaned aggressively.
WORK_DIR=./work

# Hard cap on the local disk we will use (bytes). Defaults to 900 MB to
# fit safely inside Railway's 1 GB free-tier volume.
DISK_BUDGET_BYTES=943718400

# Per-user daily download cap (bytes). 0 = unlimited.
PER_USER_DAILY_BYTES=10737418240

# Default chunk target when user picks "Auto split" (bytes). 50 MB.
DEFAULT_AUTO_PART_BYTES=52428800

# Hard upper limit on a single uploaded part (bytes). Telegram document max
# is 2 GB; we default to 1.95 GB to leave a safety margin.
MAX_PART_BYTES=2093796556

# Maximum jobs running at once across the whole bot.
MAX_CONCURRENT_JOBS=2

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./filebot.db

# --- Health endpoint ---
# Railway / Fly / Koyeb expect *something* bound to $PORT to consider the
# service alive. We expose a tiny aiohttp server on this port with /health
# (liveness) and /ready (readiness — fails when disk is nearly full).
PORT=8080
HEALTH_HOST=0.0.0.0

# --- Logging ---
LOG_LEVEL=INFO
